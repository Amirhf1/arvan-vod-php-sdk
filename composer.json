{
    "name": "arvan-vod/arvan-vod",
    "description": "",
    "keywords": [
        "arvan vod"
    ],
    "homepage": "https://github.com/Amirhf1/arvan-vod-php-sdk",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "amirhf",
            "email": "amirhacking85@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^7.4|^8.0",
        "ankitpokhrel/tus-php": "^2.3",
        "illuminate/support": "^8.0"
    },
    "require-dev": {
        "orchestra/testbench": "^6.0",
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "ArvanVOD\\ArvanVod\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ArvanVOD\\ArvanVod\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"

    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "ArvanVOD\\ArvanVod\\ArvanVodServiceProvider"
            ],
            "aliases": {
                "ArvanVod": "ArvanVOD\\ArvanVod\\ArvanVodFacade"
            }
        }
    }
}
